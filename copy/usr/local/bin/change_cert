#!/usr/bin/bash

if [[ $(uname -s) = "Linux" ]]; then
  # Illumos / SunOS
  # change cert
  NAME=$(basename /etc/apache2/ssl/*.pem .pem)
  if [[ -n "${NAME}" ]]; then
    (
      cd /etc/apache2/ssl
      openssl pkey -in ${NAME}.pem -out ${NAME}.key
      openssl crl2pkcs7 -nocrl -certfile ${NAME}.pem | openssl pkcs7 -print_certs -out ${NAME}.crt
      chmod 0600 ${NAME}.key
      chmod 0600 ${NAME}.pem
    )
    
    if [[ -f /etc/nginx/site-enabled/with-proxy-auth ]]; then
      systemctl restart nginx
    else
      systemctl restart apache2
    fi
  else
    echo "pem file is missing!"
    exit 1
  fi
fi

exit 0
